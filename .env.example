# Redis
REDIS_URL=redis://redis:6379

# SMTP (use a local dev SMTP like Mailpit: host=mailpit, port=1025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Mailpit web UI
MAILPIT_UI=http://localhost:8025

# Persist Mailpit emails (data stored in Docker named volume `tst_mailpit_data`)
# Set to false if you do not want to persist messages between restarts
MAILPIT_PERSIST=true

# Error email
ERROR_TO=devteam@example.com
ERROR_FROM=errors@example.com

# Service name
SERVICE_NAME=local-stack

# Rate limiting (ms, count)
ERROR_EMAIL_WINDOW_MS=600000
ERROR_EMAIL_MAX=3
